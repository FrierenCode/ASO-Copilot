{
  "cleanupPeriodDays": 14,
  "env": {
    "MAX_THINKING_TOKENS": "8000",
    "ENABLE_TOOL_SEARCH": "false"
  },
  "includeCoAuthoredBy": false,
  "permissions": {
    "allow": [
      "Bash(npm test:*)",
      "Bash(curl:*)",
      "Bash(pnpm install:*)",
      "Bash(pnpm:*)",
      "Bash(xargs cat:*)"
    ],
    "deny": [
      "MCPSearch"
    ]
  },
  "model": "opusplan"
}
