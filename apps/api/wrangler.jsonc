/**
 * For more details on how to configure Wrangler, refer to:
 * https://developers.cloudflare.com/workers/wrangler/configuration/
 */
{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "api",
	"main": "src/index.ts",
	"compatibility_date": "2026-02-28",
	"compatibility_flags": [
		"nodejs_compat",
		"global_fetch_strictly_public"
	],
	"assets": {
		// The path to the directory containing the `index.html` file to be served at `/`
		"directory": "./public"
	},
	"observability": {
		"enabled": true
	},
	/**
	 * D1 Database
	 * Create with: wrangler d1 create aso-copilot
	 * Apply migrations: wrangler d1 migrations apply aso-copilot
	 * Secrets (set via `wrangler secret put <NAME>`):
	 *   UID_COOKIE_SECRET            - random 32+ char string
	 *   POLAR_WEBHOOK_SECRET         - from Polar dashboard (format: whsec_...)
	 *   POLAR_ACCESS_TOKEN           - optional, Polar API key for future use
	 *   ALLOWED_ORIGIN               - comma-separated origins for credentialed CORS
	 *                                  e.g. https://app.example.com,http://localhost:3000
	 *   APP_BASE_URL                 - base URL for building magic link URLs
	 *                                  e.g. https://app.example.com
	 *   SESSION_COOKIE_SECRET        - random 32+ char string for session signing
	 *   MAGIC_LINK_SECRET            - random 32+ char string for magic link signing
	 *   USAGE_POLICY_V2_ENABLED      - set to 'true' to enable v2 quota policy
	 *                                  (anon=2 lifetime, member=5/month, pro=unlimited)
	 *                                  defaults to v1 (free=3/month) when unset/false
	 *   MAGIC_LINK_TOKEN_TTL_MINUTES - token expiry in minutes (default: 15)
	 * For local dev, create apps/api/.dev.vars:
	 *   UID_COOKIE_SECRET=<value>
	 *   POLAR_WEBHOOK_SECRET=<value>
	 *   ALLOWED_ORIGIN=http://localhost:3000
	 *   APP_BASE_URL=http://localhost:3000
	 *   SESSION_COOKIE_SECRET=<value>
	 *   MAGIC_LINK_SECRET=<value>
	 *   USAGE_POLICY_V2_ENABLED=false
	 */
	"d1_databases": [
		{
			"binding": "DB",
			"database_name": "aso-copilot",
			"database_id": "7cfd4aa4-7970-4d47-bdaa-9cdb6663c303",
			"migrations_dir": "src/db/migrations"
		}
	]
	/**
	 * Smart Placement
	 * https://developers.cloudflare.com/workers/configuration/smart-placement/#smart-placement
	 */
	// "placement": {  "mode": "smart" }
	/**
	 * Bindings
	 * Bindings allow your Worker to interact with resources on the Cloudflare Developer Platform, including
	 * databases, object storage, AI inference, real-time communication and more.
	 * https://developers.cloudflare.com/workers/runtime-apis/bindings/
	 */
	/**
	 * Environment Variables
	 * https://developers.cloudflare.com/workers/wrangler/configuration/#environment-variables
	 * Note: Use secrets to store sensitive data.
	 * https://developers.cloudflare.com/workers/configuration/secrets/
	 */
	// "vars": {  "MY_VARIABLE": "production_value" }
	/**
	 * Service Bindings (communicate between multiple Workers)
	 * https://developers.cloudflare.com/workers/wrangler/configuration/#service-bindings
	 */
	// "services": [  {   "binding": "MY_SERVICE",   "service": "my-service"  } ]
}